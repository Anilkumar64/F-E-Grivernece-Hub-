# MongoDB Connection
MONGODB_URL=mongodb+srv://username:password@cluster.mongodb.net/dbname

# Server Port
PORT=4400
NODE_ENV=development

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_SECURE=true
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-specific-password
EMAIL_FROM=noreply@yourdomain.com
EMAIL_ENABLED=true

# JWT Secrets (generate with: openssl rand -hex 32)
ACCESS_TOKEN_SECRET=your-random-secret-key-min-32-chars-generate-new
REFRESH_TOKEN_SECRET=your-random-refresh-secret-key-min-32-chars-generate-new
ACCESS_TOKEN_EXPIRY=1h
REFRESH_TOKEN_EXPIRY=7d

# SuperAdmin Configuration (optional - will be prompted during setup)
SUPERADMIN_EMAIL=superadmin@university.ac.in
SUPERADMIN_PASSWORD=

# CORS Configuration (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://yourdomain.com

# File Upload Configuration
MAX_FILE_SIZE=2097152
ALLOWED_FILE_TYPES=jpeg,jpg,png,pdf
