NODE_ENV=development
PORT=5000
MONGODB_URL=mongodb://localhost:27017/EgrievanceHub
REDIS_URL=redis://localhost:6379
ACCESS_TOKEN_SECRET=replace-with-at-least-32-random-characters
REFRESH_TOKEN_SECRET=replace-with-at-least-32-random-characters
ALLOWED_ORIGINS=http://localhost:5173
FRONTEND_URL=http://localhost:5173
EMAIL_ENABLED=false
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=replace-me
EMAIL_PASS=replace-me
EMAIL_FROM=no-reply@example.com

# AI Service
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_SECRET=change-me-ai-service-secret-min-32-chars
AI_TIMEOUT_MS=15000
AI_RETRY_ATTEMPTS=3
LOG_DIR=logs
