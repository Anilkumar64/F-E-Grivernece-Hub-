# Server
PORT=4400
NODE_ENV=development

# MongoDB
MONGODB_URL=mongodb+srv://<username>:<password>@<cluster>/<database>
TEST_MONGODB_URL=mongodb+srv://<username>:<password>@<cluster>/<test_database>

# JWT — replace with output of the node command above
ACCESS_TOKEN_SECRET=<your_generated_secret>
REFRESH_TOKEN_SECRET=<your_generated_secret>
ACCESS_TOKEN_EXPIRY=1h
REFRESH_TOKEN_EXPIRY=7d

# CORS
ALLOWED_ORIGINS=http://localhost:5173

# Email
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_SECURE=true
EMAIL_USER=your-email@example.com
EMAIL_PASS=your-app-password
EMAIL_FROM="E-Grievance Hub <no-reply@example.com>"
EMAIL_ENABLED=false

# Body limits
JSON_BODY_LIMIT=1mb
FORM_BODY_LIMIT=1mb

# Cookies
# Use `none` only when frontend and backend are on different sites and HTTPS is enabled.
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=

# Refresh token source hardening:
# Keep false in production to require refresh tokens only from HttpOnly cookies.
ALLOW_BODY_REFRESH_TOKEN=false

# Redis (leave blank to disable)
REDIS_URL=