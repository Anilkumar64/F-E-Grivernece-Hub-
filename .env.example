# MongoDB
MONGO_USER=admin
MONGO_PASS=change-me
MONGODB_URL=mongodb://localhost:27017/EgrievanceHub
TEST_MONGODB_URL=mongodb://localhost:27017/EgrievanceHub_test
MONGODB_DB=EgrievanceHub

# Backend
NODE_ENV=development
PORT=5000
JSON_BODY_LIMIT=1mb
FORM_BODY_LIMIT=1mb
LOG_DIR=logs

# Auth Secrets (replace with 64+ random characters in production)
ACCESS_TOKEN_SECRET=replace-with-at-least-64-random-characters
REFRESH_TOKEN_SECRET=replace-with-at-least-64-random-characters
ACCESS_TOKEN_EXPIRY=1h
REFRESH_TOKEN_EXPIRY=7d
COOKIE_SAMESITE=lax
ALLOW_BODY_REFRESH_TOKEN=true

# First/single superadmin seed
SUPER_NAME=Super Admin
SUPER_EMAIL=superadmin@university.ac.in
SUPER_PASSWORD=replace-with-a-strong-password
SUPERADMIN_STAFF_ID=SA-HQ-0001

# AI Service
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_SECRET=replace-with-at-least-64-random-characters
AI_TIMEOUT_MS=15000
AI_RETRY_ATTEMPTS=3
AI_REQUIRE_DB=true
BACKEND_ORIGIN=http://localhost:5000
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-flash
GEMINI_EMBEDDING_MODEL=models/text-embedding-004
PRELOAD_EMBEDDING_MODEL=false
EMBEDDING_MODEL=all-MiniLM-L6-v2
SIMILARITY_THRESHOLD=0.75
MAX_SIMILAR_RESULTS=5
HOST=0.0.0.0
LOG_LEVEL=INFO

# Frontend/CORS
ALLOWED_ORIGINS=http://localhost:5173
FRONTEND_URL=http://localhost:5173
VITE_PROXY_TARGET=http://localhost:5000
VITE_API_URL=

# Email
EMAIL_ENABLED=false
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=E-Grievance Hub <no-reply@example.com>

# SMS/Twilio
TWILIO_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# OTP
OTP_EXPIRY_MINUTES=10
OTP_LENGTH=6
