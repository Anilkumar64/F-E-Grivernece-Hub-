GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-flash
GEMINI_EMBEDDING_MODEL=models/text-embedding-004

MONGODB_URL=mongodb://localhost:27017/EgrievanceHub
MONGODB_DB=EgrievanceHub

# Internal secret shared with Node.js backend for service-to-service auth
AI_SERVICE_SECRET=change-me-ai-service-secret-min-32-chars

# Performance
EMBEDDING_MODEL=all-MiniLM-L6-v2
SIMILARITY_THRESHOLD=0.75
MAX_SIMILAR_RESULTS=5

# Server
HOST=0.0.0.0
PORT=8000
LOG_DIR=logs
LOG_LEVEL=INFO
PRELOAD_EMBEDDING_MODEL=false
